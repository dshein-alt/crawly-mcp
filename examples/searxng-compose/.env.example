# Copy this file to `.env` and edit as needed. `docker compose` picks up
# `.env` from the current working directory automatically.

# --- Container image ---
# Default: latest tagged release published to GHCR. Override to use a locally
# built image (e.g. `docker build -t crawly-mcp:local .`):
#   CRAWLY_MCP_IMAGE=localhost/crawly-mcp:local
CRAWLY_MCP_IMAGE=ghcr.io/dshein-alt/crawly-mcp:latest

# --- Host port bindings ---
# Both services bind to 127.0.0.1 only; change the compose file if you want
# them reachable from other hosts.

# Crawly's MCP HTTP transport (clients connect to http://127.0.0.1:${CRAWLY_HOST_PORT}/mcp/)
CRAWLY_HOST_PORT=10000

# SearXNG UI / API (handy for sanity-checking the instance in a browser)
SEARXNG_HOST_PORT=10080

# --- Crawly runtime ---
# TRACE | DEBUG | INFO | WARNING | ERROR | CRITICAL
CRAWLY_LOG_LEVEL=INFO
